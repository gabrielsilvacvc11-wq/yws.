<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YWS Energia Solar</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif}
        body{background:#f8f9fa}
        .header{background:#0A1F3F;color:white;padding:15px 0}
        .nav{max-width:1200px;margin:auto;display:flex;justify-content:space-between;align-items:center;padding:0 20px}
        .hero{background:linear-gradient(rgba(10,31,63,.85),rgba(10,31,63,.85)),url('https://picsum.photos/id/1015/1920/800') center/cover;color:white;text-align:center;padding:140px 20px}
        .hero h1{font-size:3.5rem}
        .hero .golaço{color:#FDB813;font-size:4.5rem}
        .simulador-box{max-width:1100px;margin:-80px auto 60px;background:white;border-radius:20px;box-shadow:0 20px 50px rgba(0,0,0,.15);overflow:hidden;display:grid;grid-template-columns:1fr 1fr}
        .form-side,.result-side{padding:50px 40px}
        input,select{width:100%;padding:14px;margin:10px 0;border:1px solid #ddd;border-radius:8px;font-size:1.1rem}
        button{width:100%;padding:18px;background:#10B981;color:white;border:none;border-radius:10px;font-size:1.2rem;cursor:pointer;margin-top:15px}
        #resultado{background:#f0fdf4}
    </style>
</head>
<body>

<div class="header">
    <div class="nav">
        <div class="logo">YWS Energia Solar</div>
        <a href="https://wa.me/5562991758807" style="background:#25D366;color:white;padding:10px 25px;border-radius:30px;text-decoration:none">WhatsApp</a>
    </div>
</div>

<div class="hero">
    <h1>MARQUE UM <span class="golaço">GOLAÇO</span> NA SUA ECONOMIA!</h1>
</div>

<div class="simulador-box">
    <div class="form-side">
        <h2>SIMULADOR FOTOVOLTAICO</h2>
        <input type="number" id="conta" value="450">
        <input type="number" id="tarifa" value="0.90" step="0.01">
        <button onclick="calcular()">CALCULAR AGORA</button>
    </div>
    <div class="result-side" id="resultado">
        <div id="result-content">Preencha e calcule</div>
    </div>
</div>

<script>
function calcular(){
    let conta = parseFloat(document.getElementById('conta').value)||450;
    let tarifa = parseFloat(document.getElementById('tarifa').value)||0.90;
    let consumo = conta / tarifa;
    let potencia = consumo / 130;
    let placas = Math.ceil(potencia*1000/550);
    let investimento = potencia*4800;
    let economiaMensal = conta*0.92;
    let payback = investimento/(economiaMensal*12);

    document.getElementById('result-content').innerHTML=`
        <strong>Economia Mensal:</strong> R$ ${economiaMensal.toFixed(2)}<br>
        <strong>Placas:</strong> ${placas}<br>
        <strong>Potência:</strong> ${potencia.toFixed(2)} kWp<br>
        <strong>Investimento:</strong> R$ ${investimento.toFixed(0)}<br>
        <strong>Payback:</strong> ${payback.toFixed(1)} anos
    `;
}
</script>

</body>
</html>
